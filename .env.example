# Database Configuration
POSTGRES_DB=restaurant_db
POSTGRES_USER=admin
POSTGRES_PASSWORD=secret123
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

MONGO_USER=admin
MONGO_PASSWORD=secret123
MONGO_HOST=mongodb
MONGO_PORT=27017
MONGO_DB=bookings

# Redis Configuration
REDIS_HOST=redis
REDIS_PORT=6379

# Security
JWT_SECRET=supersecretkey
JWT_EXPIRATION=24h

# Groq API Configuration (OpenAI-compatible endpoint)
VITE_OPENAI_API_KEY=gsk_your-groq-api-key-here
VITE_OPENAI_API_URL=https://api.groq.com/openai/v1
VITE_OPENAI_MODEL=llama-3.1-8b-instant

# Service URLs (for Docker Compose)
AI_SERVICE_URL=http://ai-service:8001
RESTAURANT_SERVICE_URL=http://restaurant-service:3001
BOOKING_SERVICE_URL=http://booking-service:8002
NOTIFICATION_SERVICE_URL=http://notification-service:3003

# Rate Limiting
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100

# Node Environment
NODE_ENV=development

# API Gateway
API_GATEWAY_PORT=3000

# AI Service
AI_SERVICE_PORT=8001
AI_MODEL=llama-3.1-8b-instant
AI_MAX_TOKENS=1024
AI_TEMPERATURE=0.7
OPENAI_API_KEY=gsk_your-groq-api-key-here
OPENAI_API_URL=https://api.groq.com/openai/v1

# Restaurant Service
RESTAURANT_SERVICE_PORT=3001

# Booking Service
BOOKING_SERVICE_PORT=8002

# Notification Service
NOTIFICATION_SERVICE_PORT=3003
NOTIFICATION_EMAIL_FROM=noreply@restaurant-booking.com
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
FRONTEND_URL=http://localhost:74

# Payments
STRIPE_SECRET_KEY=sk_test_your_stripe_secret
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret
VITE_STRIPE_PUBLIC_KEY=pk_test_your_stripe_public

# Frontend
FRONTEND_PORT=80
VITE_API_URL=http://localhost:3000

# Monitoring
PROMETHEUS_PORT=9090
GRAFANA_PORT=3001
GRAFANA_ADMIN_PASSWORD=admin123

# Logging
LOG_LEVEL=info
LOG_FORMAT=json
