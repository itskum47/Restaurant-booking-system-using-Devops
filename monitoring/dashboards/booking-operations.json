{
  "dashboard": {
    "title": "Booking Operations Dashboard",
    "tags": ["restaurant-booking", "bookings"],
    "timezone": "browser",
    "schemaVersion": 38,
    "version": 1,
    "refresh": "10s",
    "time": {
      "from": "now-24h",
      "to": "now"
    },
    "panels": [
      {
        "id": 1,
        "title": "Bookings Created Per Hour",
        "type": "graph",
        "gridPos": {"h": 8, "w": 12, "x": 0, "y": 0},
        "targets": [
          {
            "expr": "sum(rate(bookings_created_total{namespace=\"restaurant-system\"}[1h])) * 3600",
            "legendFormat": "Bookings/hour",
            "refId": "A"
          }
        ],
        "yaxes": [
          {"format": "short", "label": "Bookings"},
          {"format": "short"}
        ],
        "bars": true,
        "lines": false
      },
      {
        "id": 2,
        "title": "Booking Success Rate",
        "type": "gauge",
        "gridPos": {"h": 8, "w": 12, "x": 12, "y": 0},
        "targets": [
          {
            "expr": "(sum(rate(bookings_created_total{namespace=\"restaurant-system\"}[1h])) / (sum(rate(bookings_created_total{namespace=\"restaurant-system\"}[1h])) + sum(rate(bookings_cancelled_total{namespace=\"restaurant-system\"}[1h])))) * 100",
            "refId": "A"
          }
        ],
        "options": {
          "showThresholdLabels": false,
          "showThresholdMarkers": true
        },
        "fieldConfig": {
          "defaults": {
            "color": {"mode": "thresholds"},
            "unit": "percent",
            "min": 0,
            "max": 100,
            "thresholds": {
              "mode": "absolute",
              "steps": [
                {"color": "red", "value": null},
                {"color": "yellow", "value": 70},
                {"color": "green", "value": 90}
              ]
            }
          }
        }
      },
      {
        "id": 3,
        "title": "Bookings by Cuisine Type",
        "type": "bargauge",
        "gridPos": {"h": 8, "w": 12, "x": 0, "y": 8},
        "targets": [
          {
            "expr": "sum(bookings_created_total{namespace=\"restaurant-system\"}) by (cuisine)",
            "legendFormat": "{{cuisine}}",
            "refId": "A"
          }
        ],
        "options": {
          "orientation": "horizontal",
          "displayMode": "gradient"
        }
      },
      {
        "id": 4,
        "title": "Bookings by Party Size",
        "type": "piechart",
        "gridPos": {"h": 8, "w": 12, "x": 12, "y": 8},
        "targets": [
          {
            "expr": "sum(bookings_created_total{namespace=\"restaurant-system\"}) by (party_size_bucket)",
            "legendFormat": "{{party_size_bucket}}",
            "refId": "A"
          }
        ],
        "options": {
          "legend": {"displayMode": "table", "placement": "right"},
          "pieType": "pie"
        }
      },
      {
        "id": 5,
        "title": "Booking Processing Time",
        "type": "graph",
        "gridPos": {"h": 8, "w": 12, "x": 0, "y": 16},
        "targets": [
          {
            "expr": "histogram_quantile(0.50, sum(rate(booking_processing_duration_seconds_bucket{namespace=\"restaurant-system\"}[5m])) by (le))",
            "legendFormat": "P50",
            "refId": "A"
          },
          {
            "expr": "histogram_quantile(0.95, sum(rate(booking_processing_duration_seconds_bucket{namespace=\"restaurant-system\"}[5m])) by (le))",
            "legendFormat": "P95",
            "refId": "B"
          },
          {
            "expr": "histogram_quantile(0.99, sum(rate(booking_processing_duration_seconds_bucket{namespace=\"restaurant-system\"}[5m])) by (le))",
            "legendFormat": "P99",
            "refId": "C"
          }
        ],
        "yaxes": [
          {"format": "s", "label": "Duration"},
          {"format": "short"}
        ]
      },
      {
        "id": 6,
        "title": "Active Bookings",
        "type": "graph",
        "gridPos": {"h": 8, "w": 12, "x": 12, "y": 16},
        "targets": [
          {
            "expr": "active_bookings_total{namespace=\"restaurant-system\"}",
            "legendFormat": "Active Bookings",
            "refId": "A"
          }
        ],
        "yaxes": [
          {"format": "short", "label": "Count"},
          {"format": "short"}
        ]
      },
      {
        "id": 7,
        "title": "Cancellation Rate",
        "type": "graph",
        "gridPos": {"h": 8, "w": 12, "x": 0, "y": 24},
        "targets": [
          {
            "expr": "sum(rate(bookings_cancelled_total{namespace=\"restaurant-system\"}[5m])) by (reason)",
            "legendFormat": "{{reason}}",
            "refId": "A"
          }
        ],
        "yaxes": [
          {"format": "short", "label": "Cancellations/sec"},
          {"format": "short"}
        ],
        "stack": true
      },
      {
        "id": 8,
        "title": "Top Cancellation Reasons",
        "type": "table",
        "gridPos": {"h": 8, "w": 12, "x": 12, "y": 24},
        "targets": [
          {
            "expr": "topk(5, sum(bookings_cancelled_total{namespace=\"restaurant-system\"}) by (reason))",
            "format": "table",
            "instant": true,
            "refId": "A"
          }
        ],
        "transformations": [
          {
            "id": "organize",
            "options": {
              "excludeByName": {"Time": true},
              "indexByName": {},
              "renameByName": {"reason": "Reason", "Value": "Count"}
            }
          }
        ]
      },
      {
        "id": 9,
        "title": "Total Bookings Today",
        "type": "stat",
        "gridPos": {"h": 4, "w": 6, "x": 0, "y": 32},
        "targets": [
          {
            "expr": "sum(increase(bookings_created_total{namespace=\"restaurant-system\"}[24h]))",
            "refId": "A"
          }
        ],
        "options": {
          "colorMode": "value",
          "graphMode": "area",
          "textMode": "value_and_name"
        }
      },
      {
        "id": 10,
        "title": "Cancelled Today",
        "type": "stat",
        "gridPos": {"h": 4, "w": 6, "x": 6, "y": 32},
        "targets": [
          {
            "expr": "sum(increase(bookings_cancelled_total{namespace=\"restaurant-system\"}[24h]))",
            "refId": "A"
          }
        ],
        "options": {
          "colorMode": "value",
          "graphMode": "area",
          "textMode": "value_and_name"
        },
        "fieldConfig": {
          "defaults": {
            "color": {"mode": "thresholds"},
            "thresholds": {
              "mode": "absolute",
              "steps": [
                {"color": "green", "value": null},
                {"color": "yellow", "value": 10},
                {"color": "red", "value": 50}
              ]
            }
          }
        }
      },
      {
        "id": 11,
        "title": "Avg Processing Time",
        "type": "stat",
        "gridPos": {"h": 4, "w": 6, "x": 12, "y": 32},
        "targets": [
          {
            "expr": "rate(booking_processing_duration_seconds_sum{namespace=\"restaurant-system\"}[5m]) / rate(booking_processing_duration_seconds_count{namespace=\"restaurant-system\"}[5m])",
            "refId": "A"
          }
        ],
        "options": {
          "colorMode": "value",
          "graphMode": "area",
          "textMode": "value_and_name",
          "unit": "s"
        }
      },
      {
        "id": 12,
        "title": "Peak Hour Today",
        "type": "stat",
        "gridPos": {"h": 4, "w": 6, "x": 18, "y": 32},
        "targets": [
          {
            "expr": "max_over_time((sum(rate(bookings_created_total{namespace=\"restaurant-system\"}[1h])) * 3600)[24h:])",
            "refId": "A"
          }
        ],
        "options": {
          "colorMode": "value",
          "graphMode": "none",
          "textMode": "value_and_name"
        }
      }
    ]
  }
}
