{
  "dashboard": {
    "title": "Infrastructure Health Dashboard",
    "tags": ["restaurant-booking", "infrastructure"],
    "timezone": "browser",
    "schemaVersion": 38,
    "version": 1,
    "refresh": "30s",
    "time": {
      "from": "now-1h",
      "to": "now"
    },
    "panels": [
      {
        "id": 1,
        "title": "Cluster CPU Usage",
        "type": "graph",
        "gridPos": {"h": 8, "w": 12, "x": 0, "y": 0},
        "targets": [
          {
            "expr": "sum(rate(container_cpu_usage_seconds_total{namespace=\"restaurant-system\", pod!=\"\"}[5m])) by (pod)",
            "legendFormat": "{{pod}}",
            "refId": "A"
          }
        ],
        "yaxes": [
          {"format": "percentunit", "label": "CPU"},
          {"format": "short"}
        ],
        "stack": false
      },
      {
        "id": 2,
        "title": "Cluster Memory Usage",
        "type": "graph",
        "gridPos": {"h": 8, "w": 12, "x": 12, "y": 0},
        "targets": [
          {
            "expr": "sum(container_memory_working_set_bytes{namespace=\"restaurant-system\", pod!=\"\"}) by (pod) / 1024 / 1024 / 1024",
            "legendFormat": "{{pod}}",
            "refId": "A"
          }
        ],
        "yaxes": [
          {"format": "decgbytes", "label": "Memory"},
          {"format": "short"}
        ],
        "stack": false
      },
      {
        "id": 3,
        "title": "Pod Restart Count (Last 1h)",
        "type": "bargauge",
        "gridPos": {"h": 8, "w": 12, "x": 0, "y": 8},
        "targets": [
          {
            "expr": "sum(increase(kube_pod_container_status_restarts_total{namespace=\"restaurant-system\"}[1h])) by (pod)",
            "legendFormat": "{{pod}}",
            "refId": "A"
          }
        ],
        "options": {
          "orientation": "horizontal",
          "displayMode": "gradient"
        },
        "fieldConfig": {
          "defaults": {
            "color": {"mode": "thresholds"},
            "thresholds": {
              "mode": "absolute",
              "steps": [
                {"color": "green", "value": null},
                {"color": "yellow", "value": 1},
                {"color": "red", "value": 3}
              ]
            }
          }
        }
      },
      {
        "id": 4,
        "title": "Pod Status Summary",
        "type": "piechart",
        "gridPos": {"h": 8, "w": 12, "x": 12, "y": 8},
        "targets": [
          {
            "expr": "count(kube_pod_status_phase{namespace=\"restaurant-system\"}) by (phase)",
            "legendFormat": "{{phase}}",
            "refId": "A"
          }
        ],
        "options": {
          "legend": {"displayMode": "table", "placement": "right"},
          "pieType": "donut"
        }
      },
      {
        "id": 5,
        "title": "HPA Current vs Desired Replicas",
        "type": "graph",
        "gridPos": {"h": 8, "w": 12, "x": 0, "y": 16},
        "targets": [
          {
            "expr": "kube_horizontalpodautoscaler_status_current_replicas{namespace=\"restaurant-system\"}",
            "legendFormat": "{{horizontalpodautoscaler}} - Current",
            "refId": "A"
          },
          {
            "expr": "kube_horizontalpodautoscaler_status_desired_replicas{namespace=\"restaurant-system\"}",
            "legendFormat": "{{horizontalpodautoscaler}} - Desired",
            "refId": "B"
          }
        ],
        "yaxes": [
          {"format": "short", "label": "Replicas"},
          {"format": "short"}
        ]
      },
      {
        "id": 6,
        "title": "HPA Utilization",
        "type": "graph",
        "gridPos": {"h": 8, "w": 12, "x": 12, "y": 16},
        "targets": [
          {
            "expr": "(kube_horizontalpodautoscaler_status_current_replicas{namespace=\"restaurant-system\"} / kube_horizontalpodautoscaler_spec_max_replicas{namespace=\"restaurant-system\"}) * 100",
            "legendFormat": "{{horizontalpodautoscaler}}",
            "refId": "A"
          }
        ],
        "yaxes": [
          {"format": "percent", "label": "% of Max Replicas", "max": 100},
          {"format": "short"}
        ]
      },
      {
        "id": 7,
        "title": "PVC Usage",
        "type": "graph",
        "gridPos": {"h": 8, "w": 12, "x": 0, "y": 24},
        "targets": [
          {
            "expr": "(kubelet_volume_stats_used_bytes{namespace=\"restaurant-system\"} / kubelet_volume_stats_capacity_bytes{namespace=\"restaurant-system\"}) * 100",
            "legendFormat": "{{persistentvolumeclaim}}",
            "refId": "A"
          }
        ],
        "yaxes": [
          {"format": "percent", "label": "Usage %", "max": 100},
          {"format": "short"}
        ]
      },
      {
        "id": 8,
        "title": "Network I/O",
        "type": "graph",
        "gridPos": {"h": 8, "w": 12, "x": 12, "y": 24},
        "targets": [
          {
            "expr": "sum(rate(container_network_receive_bytes_total{namespace=\"restaurant-system\"}[5m])) by (pod) / 1024 / 1024",
            "legendFormat": "{{pod}} - RX",
            "refId": "A"
          },
          {
            "expr": "sum(rate(container_network_transmit_bytes_total{namespace=\"restaurant-system\"}[5m])) by (pod) / 1024 / 1024",
            "legendFormat": "{{pod}} - TX",
            "refId": "B"
          }
        ],
        "yaxes": [
          {"format": "MBs", "label": "MB/s"},
          {"format": "short"}
        ]
      },
      {
        "id": 9,
        "title": "Database Connections",
        "type": "graph",
        "gridPos": {"h": 8, "w": 12, "x": 0, "y": 32},
        "targets": [
          {
            "expr": "pg_stat_activity_count{namespace=\"restaurant-system\"}",
            "legendFormat": "PostgreSQL",
            "refId": "A"
          },
          {
            "expr": "mongodb_connections{namespace=\"restaurant-system\"}",
            "legendFormat": "MongoDB",
            "refId": "B"
          },
          {
            "expr": "redis_connected_clients{namespace=\"restaurant-system\"}",
            "legendFormat": "Redis",
            "refId": "C"
          }
        ],
        "yaxes": [
          {"format": "short", "label": "Connections"},
          {"format": "short"}
        ]
      },
      {
        "id": 10,
        "title": "Database Query Rate",
        "type": "graph",
        "gridPos": {"h": 8, "w": 12, "x": 12, "y": 32},
        "targets": [
          {
            "expr": "rate(restaurant_queries_total{namespace=\"restaurant-system\"}[5m])",
            "legendFormat": "Restaurant Service",
            "refId": "A"
          },
          {
            "expr": "rate(mongodb_op_counters_total{namespace=\"restaurant-system\"}[5m])",
            "legendFormat": "MongoDB",
            "refId": "B"
          }
        ],
        "yaxes": [
          {"format": "ops", "label": "Queries/sec"},
          {"format": "short"}
        ]
      },
      {
        "id": 11,
        "title": "Total Pods Running",
        "type": "stat",
        "gridPos": {"h": 4, "w": 6, "x": 0, "y": 40},
        "targets": [
          {
            "expr": "count(kube_pod_status_phase{namespace=\"restaurant-system\", phase=\"Running\"})",
            "refId": "A"
          }
        ],
        "options": {
          "colorMode": "value",
          "graphMode": "none",
          "textMode": "value_and_name"
        },
        "fieldConfig": {
          "defaults": {
            "color": {"mode": "thresholds"},
            "thresholds": {
              "mode": "absolute",
              "steps": [
                {"color": "red", "value": null},
                {"color": "yellow", "value": 10},
                {"color": "green", "value": 15}
              ]
            }
          }
        }
      },
      {
        "id": 12,
        "title": "Cluster CPU Capacity",
        "type": "stat",
        "gridPos": {"h": 4, "w": 6, "x": 6, "y": 40},
        "targets": [
          {
            "expr": "(sum(rate(container_cpu_usage_seconds_total{namespace=\"restaurant-system\"}[5m])) / sum(kube_node_status_allocatable{resource=\"cpu\"})) * 100",
            "refId": "A"
          }
        ],
        "options": {
          "colorMode": "value",
          "graphMode": "area",
          "textMode": "value_and_name",
          "unit": "percent"
        },
        "fieldConfig": {
          "defaults": {
            "color": {"mode": "thresholds"},
            "thresholds": {
              "mode": "absolute",
              "steps": [
                {"color": "green", "value": null},
                {"color": "yellow", "value": 70},
                {"color": "red", "value": 90}
              ]
            }
          }
        }
      },
      {
        "id": 13,
        "title": "Cluster Memory Capacity",
        "type": "stat",
        "gridPos": {"h": 4, "w": 6, "x": 12, "y": 40},
        "targets": [
          {
            "expr": "(sum(container_memory_working_set_bytes{namespace=\"restaurant-system\"}) / sum(kube_node_status_allocatable{resource=\"memory\"})) * 100",
            "refId": "A"
          }
        ],
        "options": {
          "colorMode": "value",
          "graphMode": "area",
          "textMode": "value_and_name",
          "unit": "percent"
        },
        "fieldConfig": {
          "defaults": {
            "color": {"mode": "thresholds"},
            "thresholds": {
              "mode": "absolute",
              "steps": [
                {"color": "green", "value": null},
                {"color": "yellow", "value": 70},
                {"color": "red", "value": 90}
              ]
            }
          }
        }
      },
      {
        "id": 14,
        "title": "Failed Pods",
        "type": "stat",
        "gridPos": {"h": 4, "w": 6, "x": 18, "y": 40},
        "targets": [
          {
            "expr": "count(kube_pod_status_phase{namespace=\"restaurant-system\", phase=\"Failed\"})",
            "refId": "A"
          }
        ],
        "options": {
          "colorMode": "value",
          "graphMode": "none",
          "textMode": "value_and_name"
        },
        "fieldConfig": {
          "defaults": {
            "color": {"mode": "thresholds"},
            "thresholds": {
              "mode": "absolute",
              "steps": [
                {"color": "green", "value": null},
                {"color": "red", "value": 1}
              ]
            }
          }
        }
      }
    ]
  }
}
