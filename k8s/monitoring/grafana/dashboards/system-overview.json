{
  "uid": "system-overview",
  "title": "System Overview",
  "tags": ["restaurant", "overview"],
  "timezone": "browser",
  "refresh": "30s",
  "time": { "from": "now-1h", "to": "now" },
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Booking Service Uptime",
      "gridPos": { "x": 0, "y": 0, "w": 6, "h": 4 },
      "targets": [{
        "datasource": { "uid": "prometheus" },
        "expr": "up{job='booking-service'}",
        "legendFormat": "Booking Service"
      }],
      "options": { "colorMode": "background", "graphMode": "none" },
      "fieldConfig": {
        "defaults": { "thresholds": { "steps": [
          { "color": "red", "value": 0 },
          { "color": "green", "value": 1 }
        ]}, "mappings": [
          { "type": "value", "options": { "0": { "text": "DOWN" }, "1": { "text": "UP" } } }
        ]}
      }
    },
    {
      "id": 2,
      "type": "stat",
      "title": "AI Service Uptime",
      "gridPos": { "x": 6, "y": 0, "w": 6, "h": 4 },
      "targets": [{
        "datasource": { "uid": "prometheus" },
        "expr": "up{job='ai-service'}",
        "legendFormat": "AI Service"
      }],
      "options": { "colorMode": "background", "graphMode": "none" },
      "fieldConfig": {
        "defaults": { "thresholds": { "steps": [
          { "color": "red", "value": 0 },
          { "color": "green", "value": 1 }
        ]}, "mappings": [
          { "type": "value", "options": { "0": { "text": "DOWN" }, "1": { "text": "UP" } } }
        ]}
      }
    },
    {
      "id": 3,
      "type": "timeseries",
      "title": "HTTP Request Rate (req/s)",
      "gridPos": { "x": 0, "y": 4, "w": 12, "h": 8 },
      "targets": [
        {
          "datasource": { "uid": "prometheus" },
          "expr": "sum(rate(http_requests_total[2m])) by (job)",
          "legendFormat": "{{ job }}"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "reqps" } }
    },
    {
      "id": 4,
      "type": "timeseries",
      "title": "P95 Latency (ms)",
      "gridPos": { "x": 12, "y": 4, "w": 12, "h": 8 },
      "targets": [
        {
          "datasource": { "uid": "prometheus" },
          "expr": "histogram_quantile(0.95, sum(rate(http_request_duration_seconds_bucket[5m])) by (le, job)) * 1000",
          "legendFormat": "{{ job }} p95"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "ms" } }
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "Error Rate (%)",
      "gridPos": { "x": 0, "y": 12, "w": 12, "h": 8 },
      "targets": [
        {
          "datasource": { "uid": "prometheus" },
          "expr": "sum(rate(http_requests_total{status=~'5..'}[5m])) by (job) / sum(rate(http_requests_total[5m])) by (job) * 100",
          "legendFormat": "{{ job }} error %"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "percent" } }
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "Pod CPU Usage",
      "gridPos": { "x": 12, "y": 12, "w": 12, "h": 8 },
      "targets": [
        {
          "datasource": { "uid": "prometheus" },
          "expr": "sum(rate(container_cpu_usage_seconds_total{namespace='restaurant-system'}[2m])) by (pod)",
          "legendFormat": "{{ pod }}"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "percentunit" } }
    }
  ]
}
