{
  "uid": "business-metrics",
  "title": "Business Metrics",
  "tags": ["restaurant", "business"],
  "timezone": "browser",
  "refresh": "1m",
  "time": { "from": "now-24h", "to": "now" },
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Revenue Today (USD)",
      "gridPos": { "x": 0, "y": 0, "w": 6, "h": 4 },
      "targets": [{
        "datasource": { "uid": "prometheus" },
        "expr": "sum(increase(payment_amount_total[24h]))"
      }],
      "fieldConfig": { "defaults": { "unit": "currencyUSD" } }
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Bookings Today",
      "gridPos": { "x": 6, "y": 0, "w": 6, "h": 4 },
      "targets": [{
        "datasource": { "uid": "prometheus" },
        "expr": "sum(increase(bookings_created_total[24h]))"
      }],
      "fieldConfig": { "defaults": { "unit": "short" } }
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Avg Party Size",
      "gridPos": { "x": 12, "y": 0, "w": 6, "h": 4 },
      "targets": [{
        "datasource": { "uid": "prometheus" },
        "expr": "avg(booking_party_size_avg)"
      }],
      "fieldConfig": { "defaults": { "unit": "short", "decimals": 1 } }
    },
    {
      "id": 4,
      "type": "stat",
      "title": "Waitlist Queue Size",
      "gridPos": { "x": 18, "y": 0, "w": 6, "h": 4 },
      "targets": [{
        "datasource": { "uid": "prometheus" },
        "expr": "waitlist_queue_size"
      }],
      "fieldConfig": {
        "defaults": { "unit": "short", "thresholds": { "steps": [
          { "color": "green", "value": 0 },
          { "color": "orange", "value": 10 },
          { "color": "red", "value": 25 }
        ]}}
      }
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "Bookings Over Time (24h)",
      "gridPos": { "x": 0, "y": 4, "w": 12, "h": 8 },
      "targets": [{
        "datasource": { "uid": "prometheus" },
        "expr": "sum(rate(bookings_created_total[30m])) * 1800",
        "legendFormat": "Bookings per 30m"
      }],
      "fieldConfig": { "defaults": { "unit": "short" } }
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "Revenue Over Time (24h)",
      "gridPos": { "x": 12, "y": 4, "w": 12, "h": 8 },
      "targets": [{
        "datasource": { "uid": "prometheus" },
        "expr": "sum(rate(payment_amount_total[30m])) * 1800",
        "legendFormat": "Revenue per 30m"
      }],
      "fieldConfig": { "defaults": { "unit": "currencyUSD" } }
    },
    {
      "id": 7,
      "type": "piechart",
      "title": "Bookings by Party Size",
      "gridPos": { "x": 0, "y": 12, "w": 8, "h": 8 },
      "targets": [{
        "datasource": { "uid": "prometheus" },
        "expr": "sum(bookings_created_total) by (party_size_bucket)",
        "legendFormat": "{{ party_size_bucket }}"
      }]
    },
    {
      "id": 8,
      "type": "timeseries",
      "title": "Cancellations by Reason",
      "gridPos": { "x": 8, "y": 12, "w": 16, "h": 8 },
      "targets": [{
        "datasource": { "uid": "prometheus" },
        "expr": "sum(rate(bookings_cancelled_total[30m])) by (reason) * 1800",
        "legendFormat": "{{ reason }}"
      }]
    }
  ]
}
