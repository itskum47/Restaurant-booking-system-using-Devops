{
  "uid": "booking-service",
  "title": "Booking Service",
  "tags": ["restaurant", "booking"],
  "timezone": "browser",
  "refresh": "30s",
  "time": { "from": "now-1h", "to": "now" },
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Total Bookings Created",
      "gridPos": { "x": 0, "y": 0, "w": 6, "h": 4 },
      "targets": [{
        "datasource": { "uid": "prometheus" },
        "expr": "sum(bookings_created_total)",
        "legendFormat": "Total"
      }],
      "options": { "colorMode": "value", "graphMode": "area" },
      "fieldConfig": { "defaults": { "unit": "short" } }
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Active Bookings",
      "gridPos": { "x": 6, "y": 0, "w": 6, "h": 4 },
      "targets": [{
        "datasource": { "uid": "prometheus" },
        "expr": "active_bookings_total",
        "legendFormat": "Active"
      }],
      "options": { "colorMode": "value", "graphMode": "area" },
      "fieldConfig": { "defaults": { "unit": "short" } }
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Cancellation Rate (%)",
      "gridPos": { "x": 12, "y": 0, "w": 6, "h": 4 },
      "targets": [{
        "datasource": { "uid": "prometheus" },
        "expr": "rate(bookings_cancelled_total[5m]) / rate(bookings_created_total[5m]) * 100"
      }],
      "options": { "colorMode": "background" },
      "fieldConfig": {
        "defaults": { "unit": "percent", "thresholds": { "steps": [
          { "color": "green", "value": 0 },
          { "color": "orange", "value": 10 },
          { "color": "red", "value": 25 }
        ]}}
      }
    },
    {
      "id": 4,
      "type": "timeseries",
      "title": "Booking Creation Rate (bookings/min)",
      "gridPos": { "x": 0, "y": 4, "w": 12, "h": 8 },
      "targets": [{
        "datasource": { "uid": "prometheus" },
        "expr": "sum(rate(bookings_created_total[1m])) * 60",
        "legendFormat": "Bookings/min"
      }],
      "fieldConfig": { "defaults": { "unit": "short" } }
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "Booking Processing Duration (p50 / p95 / p99)",
      "gridPos": { "x": 12, "y": 4, "w": 12, "h": 8 },
      "targets": [
        {
          "datasource": { "uid": "prometheus" },
          "expr": "histogram_quantile(0.50, rate(booking_processing_duration_seconds_bucket[5m]))",
          "legendFormat": "p50"
        },
        {
          "datasource": { "uid": "prometheus" },
          "expr": "histogram_quantile(0.95, rate(booking_processing_duration_seconds_bucket[5m]))",
          "legendFormat": "p95"
        },
        {
          "datasource": { "uid": "prometheus" },
          "expr": "histogram_quantile(0.99, rate(booking_processing_duration_seconds_bucket[5m]))",
          "legendFormat": "p99"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "s" } }
    },
    {
      "id": 6,
      "type": "piechart",
      "title": "Bookings by Cuisine Type",
      "gridPos": { "x": 0, "y": 12, "w": 8, "h": 8 },
      "targets": [{
        "datasource": { "uid": "prometheus" },
        "expr": "sum(bookings_created_total) by (cuisine_type)",
        "legendFormat": "{{ cuisine_type }}"
      }]
    },
    {
      "id": 7,
      "type": "logs",
      "title": "Recent Booking Errors",
      "gridPos": { "x": 8, "y": 12, "w": 16, "h": 8 },
      "targets": [{
        "datasource": { "uid": "loki" },
        "expr": "{service=\"booking-service\"} |= \"error\"",
        "legendFormat": ""
      }],
      "options": { "showLabels": true, "showTime": true }
    }
  ]
}
